# AI Commerce Studio — Unified Environment Template (Sprint 18 RC)
# Copy to repo root: cp env/env.template .env
# Environment-specific overrides: .env.development | .env.test | .env.production

# ── Runtime ──
APP_ENV=development
NODE_ENV=development

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_commerce_studio?schema=public

# ── Redis & Queue ──
REDIS_URL=redis://localhost:6379
# Dev: memory queue (no separate worker required)
USE_MEMORY_QUEUE=true
USE_REDIS_QUEUE=false
# Prod / RC: BullMQ via Redis (requires worker process)
# USE_MEMORY_QUEUE=false
# USE_REDIS_QUEUE=true
WORKER_CONCURRENCY=2

# ── API ──
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001

# ── Admin (frontend only) ──
ADMIN_PORT=3002
ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_API_BASE=http://localhost:3001

# ── Desktop ──
DESKTOP_URL=http://localhost:5173

# ── Auth ──
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Storage / CDN (Sprint 22) ──
STORAGE_DRIVER=auto
# r2 | cos | oss | local
STORAGE_ACCESS_KEY=
STORAGE_SECRET=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=
STORAGE_LOCAL_DIR=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_REGION=oss-cn-hangzhou
OSS_PUBLIC_BASE_URL=

# Cloudflare R2
# STORAGE_DRIVER=r2|cos|oss|local
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# 腾讯云 COS
COS_ACCESS_KEY=
COS_SECRET_KEY=
COS_ENDPOINT=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=

# ── Desktop Distribution (Sprint 21/22) ──
DOWNLOAD_DIR=./download
DOWNLOAD_BASE_URL=https://download.xxx.com
VITE_UPDATE_JSON_URL=https://download.xxx.com/update.json
# Dev:
# DOWNLOAD_BASE_URL=http://localhost:3001/download
# VITE_UPDATE_JSON_URL=http://localhost:3001/update.json

# ── AI ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_MODEL=seedream-3-0-t2i-250415
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ── Payment ──
PAYMENT_MODE=mock
WECHAT_MCH_ID=
WECHAT_APP_ID=
ALIPAY_APP_ID=

# ── Ops ──
LOG_LEVEL=info
LOG_DIR=./logs
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
API_SIGN_SECRET=
AI_TIMEOUT_MS=60000
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RESET_MS=60000
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
