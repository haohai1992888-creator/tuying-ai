# AI Commerce Studio — Environment Template
# Unified source: env/env.template (Sprint 18 RC)
# Copy: cp env/env.template .env

# ── Runtime ──
APP_ENV=development
NODE_ENV=development
APP_VERSION=1.0.0-rc

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_commerce_studio?schema=public

# ── Redis & Queue ──
REDIS_URL=redis://localhost:6379
USE_MEMORY_QUEUE=true
USE_REDIS_QUEUE=false
WORKER_CONCURRENCY=2

# ── Services ──
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
ADMIN_PORT=3002
ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_API_BASE=http://localhost:3001
DESKTOP_URL=http://localhost:5173

# ── Auth ──
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Storage ──
STORAGE_DRIVER=auto
STORAGE_LOCAL_DIR=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_REGION=oss-cn-hangzhou
OSS_PUBLIC_BASE_URL=

# ── AI ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_MODEL=seedream-3-0-t2i-250415
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ── Payment ──
PAYMENT_MODE=mock
WECHAT_MCH_ID=
WECHAT_APP_ID=
ALIPAY_APP_ID=

# ── Ops ──
LOG_LEVEL=info
LOG_DIR=./logs
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
API_SIGN_SECRET=
AI_TIMEOUT_MS=60000
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RESET_MS=60000
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
