generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  VIP
  ADMIN
}

enum UserPlan {
  FREE
  VIP
  ENTERPRISE
}

enum SubscriptionOrderStatus {
  PENDING
  PAID
  CLOSED
  REFUNDED
}

enum ReleaseChannel {
  STABLE
  BETA
}

enum ClientPlatform {
  WINDOWS
  MACOS
  LINUX
}

enum UserStatus {
  ACTIVE
  DISABLED
  BANNED
}

enum TaskStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum PointType {
  RECHARGE
  CONSUME
  REFUND
  GIFT
  SIGN_IN
}

enum OrderStatus {
  PENDING
  PAID
  CLOSED
  REFUNDED
}

enum PaymentMethod {
  WECHAT
  ALIPAY
}

enum FileCategory {
  ORIGINAL
  GENERATED
  THUMBNAIL
  TEMP
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  TIMEOUT
}

enum WorkflowNodeRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
  TIMEOUT
}

enum BatchStatus {
  PENDING
  PROCESSING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  PAUSED
  CANCELLED
}

enum DetailTaskStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum DetailBlockType {
  BANNER
  FEATURE
  SIZE
  DETAIL
  SCENE
  PARAMETER
  BRAND
  REASON
}

enum DetailPlatform {
  TAOBAO
  PINDUODUO
  DOUYIN
  XIAOHONGSHU
  OZON
  AMAZON
}

enum VideoStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum VideoTemplateType {
  PRODUCT_ROTATE
  SCENE_PUSH
  ZOOM_IN
  UNBOXING
  MARKETING
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  MODEL_ISSUE
  FEATURE_REQUEST
}

enum FeedbackStatus {
  OPEN
  REPLIED
  CLOSED
}

model User {
  id          String     @id @default(cuid())
  email       String?    @unique
  phone       String?    @unique
  password    String
  avatar      String?
  nickname    String?
  role        UserRole   @default(USER)
  plan        UserPlan   @default(FREE)
  points      Int        @default(100)
  vipExpireAt  DateTime? @map("vip_expire_time")
  betaUser     Boolean   @default(false) @map("beta_user")
  betaExpireAt DateTime? @map("beta_expire_at")
  betaPoints   Int       @default(0) @map("beta_points")
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tasks               Task[]
  pointLogs           PointLog[]
  orders              Order[]
  subscriptionOrders  SubscriptionOrder[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  files              File[]
  batchTasks         BatchTask[]
  favoriteTemplates  FavoriteTemplate[]
  templateUsages     TemplateUsage[]
  recentTemplates    RecentTemplate[]
  detailTasks        DetailTask[]
  videoTasks         VideoTask[]
  analyticsEvents    AnalyticsEvent[]
  userStats          UserStats[]
  inviteCodeUsages   InviteCodeUsage[]
  feedbacks          Feedback[]

  @@index([betaUser])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Task {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  taskType    String     @map("task_type")
  status      TaskStatus @default(PENDING)
  cost        Int        @default(0)
  inputUrl    String?    @map("input_url")
  outputUrl   String?    @map("output_url")
  modelName   String?    @map("model_name")
  batchTaskId String?    @map("batch_task_id")
  batchItemId String?    @unique @map("batch_item_id")
  createdAt   DateTime   @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  batchTask    BatchTask?    @relation(fields: [batchTaskId], references: [id], onDelete: SetNull)
  batchItem    BatchItem?    @relation(fields: [batchItemId], references: [id], onDelete: SetNull)
  workflowRuns WorkflowRun[]

  @@index([userId])
  @@index([status])
  @@index([taskType])
  @@index([batchTaskId])
  @@map("tasks")
}

model PointLog {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      PointType
  amount    Int
  balance   Int
  remark    String?
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("point_logs")
}

model Order {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  orderNo         String         @unique @map("order_no")
  amount          Decimal        @db.Decimal(10, 2)
  points          Int            @default(0)
  status          OrderStatus    @default(PENDING)
  paymentMethod   PaymentMethod? @map("payment_method")
  packageId       String?        @map("package_id")
  externalTradeNo String?        @unique @map("external_trade_no")
  paidAt          DateTime?      @map("paid_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  package PointPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([orderNo])
  @@map("orders")
}

model PointPackage {
  id        String   @id @default(cuid())
  name      String
  points    Int
  price     Decimal  @db.Decimal(10, 2)
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("point_packages")
}

model File {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  fileName    String       @map("file_name")
  fileType    String       @map("file_type")
  fileSize    Int          @map("file_size")
  category    FileCategory @default(ORIGINAL)
  storagePath String       @map("storage_path")
  publicUrl   String       @map("public_url")
  width       Int?
  height      Int?
  createdAt   DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@map("files")
}

model WorkflowRun {
  id         String             @id @default(cuid())
  workflowId String             @map("workflow_id")
  taskId     String             @map("task_id")
  status     WorkflowRunStatus  @default(PENDING)
  error      String?
  startedAt  DateTime           @default(now()) @map("started_at")
  endedAt    DateTime?          @map("ended_at")

  task     Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  nodeRuns WorkflowNodeRun[]

  @@index([taskId])
  @@index([workflowId])
  @@index([status])
  @@map("workflow_runs")
}

model WorkflowNodeRun {
  id            String                @id @default(cuid())
  workflowRunId String                @map("workflow_run_id")
  nodeId        String                @map("node_id")
  nodeType      String                @map("node_type")
  status        WorkflowNodeRunStatus @default(PENDING)
  error         String?
  startedAt     DateTime              @default(now()) @map("started_at")
  endedAt       DateTime?             @map("ended_at")

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
  @@index([status])
  @@map("workflow_node_runs")
}

model ModelUsage {
  id        String   @id @default(cuid())
  provider  String
  taskType  String   @map("task_type")
  taskId    String?  @map("task_id")
  userId    String?  @map("user_id")
  success   Boolean
  duration  Int
  cost      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([provider])
  @@index([taskType])
  @@index([success])
  @@index([createdAt])
  @@map("model_usage")
}

model BatchTask {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  taskType      String      @map("task_type")
  totalCount    Int         @map("total_count")
  successCount  Int         @default(0) @map("success_count")
  failedCount   Int         @default(0) @map("failed_count")
  status        BatchStatus @default(PENDING)
  options       Json?
  sourceType    String?     @map("source_type")
  resultZipUrl  String?     @map("result_zip_url")
  paused        Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at")
  completedAt   DateTime?   @map("completed_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items BatchItem[]
  tasks Task[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("batch_tasks")
}

model BatchItem {
  id          String     @id @default(cuid())
  batchTaskId String     @map("batch_task_id")
  inputUrl    String     @map("input_url")
  outputUrl   String?    @map("output_url")
  status      TaskStatus @default(PENDING)
  error       String?
  itemIndex   Int        @map("item_index")
  createdAt   DateTime   @default(now()) @map("created_at")

  batchTask BatchTask @relation(fields: [batchTaskId], references: [id], onDelete: Cascade)
  task      Task?

  @@index([batchTaskId])
  @@index([status])
  @@map("batch_items")
}

model SubscriptionPlan {
  id        String   @id @default(cuid())
  name      String
  planCode  String   @map("plan_code")
  price     Decimal  @db.Decimal(10, 2)
  points    Int
  duration  Int
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders SubscriptionOrder[]

  @@index([planCode])
  @@map("subscription_plans")
}

model SubscriptionOrder {
  id              String                  @id @default(cuid())
  userId          String                  @map("user_id")
  planId          String                  @map("plan_id")
  planCode        String                  @map("plan_code")
  orderNo         String                  @unique @map("order_no")
  amount          Decimal                 @db.Decimal(10, 2)
  status          SubscriptionOrderStatus @default(PENDING)
  paymentMethod   PaymentMethod?          @map("payment_method")
  externalTradeNo String?                 @unique @map("external_trade_no")
  expireAt        DateTime                @map("expire_at")
  paidAt          DateTime?               @map("paid_at")
  createdAt       DateTime                @default(now()) @map("created_at")

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@index([orderNo])
  @@map("subscription_orders")
}

model AppVersion {
  id                 String         @id @default(cuid())
  version            String
  title              String
  description        String
  downloadUrl        String         @map("download_url")
  downloadUrlWin     String?        @map("download_url_win")
  downloadUrlMac     String?        @map("download_url_mac")
  updateSignatureWin String?        @map("update_signature_win")
  updateSignatureMac String?        @map("update_signature_mac")
  pubDate            DateTime?      @map("pub_date")
  forceUpdate        Boolean        @default(false) @map("force_update")
  channel            ReleaseChannel @default(STABLE)
  published          Boolean        @default(false)
  downloadCount      Int            @default(0) @map("download_count")
  createdAt          DateTime       @default(now()) @map("created_at")

  releaseNotes ReleaseNote[]

  @@unique([version, channel])
  @@index([channel, published])
  @@map("app_versions")
}

model VersionRollout {
  id        String         @id @default(cuid())
  version   String
  force     Boolean        @default(false)
  percent   Int            @default(100)
  channel   ReleaseChannel @default(STABLE)
  createdAt DateTime       @default(now()) @map("created_at")

  @@unique([version, channel])
  @@map("version_rollouts")
}

model ReleaseNote {
  id        String   @id @default(cuid())
  versionId String?  @map("version_id")
  version   String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  appVersion AppVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([version])
  @@map("release_notes")
}

model DownloadLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  version   String
  platform  String?
  channel   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([version])
  @@index([createdAt])
  @@map("download_logs")
}

model PromptTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  variables Json?
  createdAt DateTime @default(now()) @map("created_at")

  templates Template[]

  @@map("prompt_templates")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  coverUrl    String   @map("cover_url")
  workflowId  String   @map("workflow_id")
  taskType    String   @map("task_type")
  promptId    String   @map("prompt_id")
  enabled     Boolean  @default(true)
  isVip       Boolean  @default(false) @map("is_vip")
  usageCount  Int      @default(0) @map("usage_count")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  prompt   PromptTemplate     @relation(fields: [promptId], references: [id], onDelete: Restrict)
  favorites FavoriteTemplate[]
  usages   TemplateUsage[]
  recents  RecentTemplate[]

  @@index([category])
  @@index([enabled])
  @@index([usageCount])
  @@map("templates")
}

model FavoriteTemplate {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  templateId String   @map("template_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([userId])
  @@map("favorite_templates")
}

model TemplateUsage {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([userId])
  @@index([createdAt])
  @@map("template_usages")
}

model RecentTemplate {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  templateId String   @map("template_id")
  usedAt     DateTime @default(now()) @map("used_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([userId, usedAt])
  @@map("recent_templates")
}

model DetailTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  coverUrl    String   @map("cover_url")
  blockTypes  Json     @map("block_types")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  detailTasks DetailTask[]

  @@index([category])
  @@index([enabled])
  @@map("detail_templates")
}

model DetailTask {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  templateId    String?          @map("template_id")
  productName   String           @map("product_name")
  inputUrl      String           @map("input_url")
  platform      DetailPlatform   @default(TAOBAO)
  sellingPoints Json?            @map("selling_points")
  status        DetailTaskStatus @default(PENDING)
  resultUrl     String?          @map("result_url")
  cost          Int              @default(20)
  error         String?
  createdAt     DateTime         @default(now()) @map("created_at")
  completedAt   DateTime?        @map("completed_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template DetailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  blocks   DetailBlock[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("detail_tasks")
}

model DetailBlock {
  id           String          @id @default(cuid())
  detailTaskId String          @map("detail_task_id")
  blockType    DetailBlockType @map("block_type")
  sortOrder    Int             @default(0) @map("sort_order")
  status       TaskStatus      @default(PENDING)
  imageUrl     String?         @map("image_url")
  prompt       String?
  provider     String?
  error        String?
  createdAt    DateTime        @default(now()) @map("created_at")

  detailTask DetailTask @relation(fields: [detailTaskId], references: [id], onDelete: Cascade)

  @@index([detailTaskId])
  @@index([blockType])
  @@map("detail_blocks")
}

model VideoTemplate {
  id          String            @id @default(cuid())
  name        String
  description String
  templateType VideoTemplateType @map("template_type")
  coverUrl    String            @map("cover_url")
  enabled     Boolean           @default(true)
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at")

  videoTasks VideoTask[]

  @@index([enabled])
  @@index([templateType])
  @@map("video_templates")
}

model VideoTask {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  templateId  String?     @map("template_id")
  inputUrl    String      @map("input_url")
  productName String?     @map("product_name")
  provider    String
  duration    Int         @default(5)
  prompt      String?
  status      VideoStatus @default(PENDING)
  progress    Int         @default(0)
  cost        Int         @default(20)
  videoUrl    String?     @map("video_url")
  error       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  completedAt DateTime?   @map("completed_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template VideoTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("video_tasks")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  eventType String   @map("event_type")
  module    String
  action    String
  metadata  Json?
  cost      Decimal? @db.Decimal(12, 4)
  revenue   Decimal? @db.Decimal(12, 4)
  duration  Int?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([module])
  @@index([createdAt])
  @@map("analytics_events")
}

model UserStats {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  date          DateTime @db.Date
  generateCount Int      @default(0) @map("generate_count")
  cost          Decimal  @default(0) @db.Decimal(12, 4)
  revenue       Decimal  @default(0) @db.Decimal(12, 4)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@map("user_stats")
}

model ModelStats {
  id      String   @id @default(cuid())
  model   String
  date    DateTime @db.Date
  calls   Int      @default(0)
  success Int      @default(0)
  fail    Int      @default(0)
  cost    Decimal  @default(0) @db.Decimal(12, 4)

  @@unique([model, date])
  @@index([date])
  @@map("model_stats")
}

model FeatureStats {
  id      String   @id @default(cuid())
  module  String
  date    DateTime @db.Date
  usage   Int      @default(0)
  revenue Decimal  @default(0) @db.Decimal(12, 4)
  cost    Decimal  @default(0) @db.Decimal(12, 4)

  @@unique([module, date])
  @@index([date])
  @@map("feature_stats")
}

model Alert {
  id        String   @id @default(cuid())
  message   String
  level     String   @default("info")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([resolved])
  @@index([createdAt])
  @@map("alerts")
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  maxCount  Int       @map("max_count")
  usedCount Int       @default(0) @map("used_count")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  usages InviteCodeUsage[]

  @@map("invite_codes")
}

model InviteCodeUsage {
  id           String   @id @default(cuid())
  inviteCodeId String   @map("invite_code_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inviteCodeId])
  @@index([userId])
  @@map("invite_code_usages")
}

model Feedback {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  category   FeedbackCategory
  content    String
  status     FeedbackStatus   @default(OPEN)
  adminReply String?          @map("admin_reply")
  taskId     String?          @map("task_id")
  model      String?
  error      String?
  prompt     String?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("feedbacks")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  startAt   DateTime @map("start_at")
  endAt     DateTime @map("end_at")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([startAt, endAt])
  @@index([enabled])
  @@map("announcements")
}
