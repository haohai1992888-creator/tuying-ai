# AI Commerce Studio — Release Candidate (.env.production)
# cp env/env.template .env.production && fill secrets

APP_ENV=production
NODE_ENV=production
APP_VERSION=1.0.0-rc

# ── Database ──
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/ai_commerce_studio?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ai_commerce_studio

# ── Redis & BullMQ (required for RC) ──
REDIS_URL=redis://redis:6379
USE_MEMORY_QUEUE=false
USE_REDIS_QUEUE=true
WORKER_CONCURRENCY=2

# ── Services ──
API_PORT=3001
API_PUBLIC_URL=https://api.example.com
ADMIN_PORT=3002
ADMIN_URL=https://admin.example.com
NEXT_PUBLIC_API_BASE=https://api.example.com
DESKTOP_URL=https://desktop.example.com

# ── Auth ──
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Storage ──
STORAGE_DRIVER=auto
STORAGE_LOCAL_DIR=/app/storage
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_REGION=oss-cn-hangzhou
OSS_PUBLIC_BASE_URL=

# ── AI ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_MODEL=seedream-3-0-t2i-250415
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ── Payment ──
PAYMENT_MODE=mock
WECHAT_MCH_ID=
WECHAT_APP_ID=
ALIPAY_APP_ID=

# ── Ops ──
LOG_LEVEL=info
LOG_DIR=/app/logs
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
API_SIGN_SECRET=
AI_TIMEOUT_MS=60000
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RESET_MS=60000
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
