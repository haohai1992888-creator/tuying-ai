{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI-Commerce",
  "mainBinaryName": "AI-Commerce",
  "version": "1.0.0",
  "identifier": "com.acs.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI 电商工作台",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "AI 电商工作台"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "bundleName": "AI-Commerce"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/haohai1992888-creator/tuying-ai/releases/download/v1.0.0/update.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDAwMDAwMDAwMDAwMDAwMApRUndCQdYQ7XJXQnJ4VXFicGJ6V0Z1YjNOMGNtbHVaejA9Cg=="
    }
  }
}
