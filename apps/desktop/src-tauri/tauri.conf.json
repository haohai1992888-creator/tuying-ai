{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Commerce",
  "version": "1.0.0",
  "identifier": "com.acs.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Commerce Studio",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "target": ["nsis"],
      "nsis": {
        "installerFilename": "AI-Commerce-Setup"
      }
    },
    "macOS": {
      "targets": ["dmg"],
      "minimumSystemVersion": "10.15",
      "dmg": {
        "artifactName": "AI-Commerce"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "http://localhost:3001/update.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDAwMDAwMDAwMDAwMDAwMApRUndCQdYQ7XJXQnJ4VXFicGJ6V0Z1YjNOMGNtbHVaejA9Cg=="
    }
  }
}
